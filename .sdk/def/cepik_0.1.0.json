  "components": {
    "schemas": {
      "Vehicle": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique vehicle identifier"
          },
          "marka": {
            "type": "string",
            "description": "Vehicle brand/make"
          },
          "model": {
            "type": "string",
            "description": "Vehicle model"
          },
          "rodzaj": {
            "type": "string",
            "description": "Vehicle type"
          },
          "podrodzaj": {
            "type": "string",
            "description": "Vehicle subtype"
          },
          "rok-produkcji": {
            "type": "integer",
            "description": "Year of production"
          },
          "pojemnosc-silnika": {
            "type": "integer",
            "description": "Engine capacity in cm³"
          },
          "masa-wlasna": {
            "type": "integer",
            "description": "Curb weight in kg"
          },
          "wojewodztwo": {
            "type": "string",
            "description": "Province/voivodeship of registration"
          },
          "data-pierwszej-rejestracji": {
            "type": "string",
            "format": "date",
            "description": "Date of first registration"
          }
        }
      },
      "DrivingLicense": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique license identifier"
          },
          "kategoria": {
            "type": "string",
            "description": "License category"
          },
          "data-wydania": {
            "type": "string",
            "format": "date",
            "description": "Date of issue"
          },
          "data-waznosci": {
            "type": "string",
            "format": "date",
            "description": "Expiry date"
          },
          "wojewodztwo": {
            "type": "string",
            "description": "Province/voivodeship of issue"
          }
        }
      },
      "Permission": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique permission identifier"
          },
          "kategoria": {
            "type": "string",
            "description": "Category of permission"
          },
          "data-uzyskania": {
            "type": "string",
            "format": "date",
            "description": "Date permission was obtained"
          },
          "wojewodztwo": {
            "type": "string",
            "description": "Province/voivodeship"
          }
        }
      },
      "VehicleStatistics": {
        "type": "object",
        "properties": {
          "wojewodztwo": {
            "type": "string",
            "description": "Province/voivodeship"
          },
          "liczba-pojazdow": {
            "type": "integer",
            "description": "Total number of vehicles"
          },
          "wg-rodzaju": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            },
            "description": "Breakdown by vehicle type"
          },
          "wg-marki": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            },
            "description": "Breakdown by brand"
          }
        }
      },
      "DrivingLicenseStatistics": {
        "type": "object",
        "properties": {
          "wojewodztwo": {
            "type": "string",
            "description": "Province/voivodeship"
          },
          "liczba-praw-jazdy": {
            "type": "integer",
            "description": "Total number of driving licenses"
          },
          "wg-kategorii": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            },
            "description": "Breakdown by license category"
          }
        }
      },
      "PaginationLinks": {
        "type": "object",
        "properties": {
          "first": {
            "type": "string",
            "description": "URL to first page"
          },
          "last": {
            "type": "string",
            "description": "URL to last page"
          },
          "prev": {
            "type": "string",
            "nullable": true,
            "description": "URL to previous page"
          },
          "next": {
            "type": "string",
            "nullable": true,
            "description": "URL to next page"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "code": {
            "type": "integer",
            "description": "Error code"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Vehicles",
      "description": "Operations related to vehicle data"
    },
    {
      "name": "Driving Licenses",
      "description": "Operations related to driving license data"
    },
    {
      "name": "Permissions",
      "description": "Operations related to vehicle driving permissions"
    },
    {
      "name": "Statistics",
      "description": "Statistical information about vehicles and driving licenses"
    }
  ]
}
